module binary_expr;

fn main() -> void {
    let a: int = 6 + 7;
    let b: int = 7 * 7 - 2;
    let c: int = 7 / (7 * 2) & 3;
    let d: int = 1200 % 4;
    let e: int = 7 ^ 7 & 4 | 3 * 7;

    let f: bool = true && false;
    let g: bool = false || false && true;
    let h: bool = 6 < 9;
    let i: bool = 6 > 9;
    let j: bool = 6 == 9;
    let k: bool = 6 != 177;
    let l: bool = 6 == 6 && 7 != 6;
}