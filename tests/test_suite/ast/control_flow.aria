module control_flow;

fn main() -> void {
    let a: ulong = 0;

    while true && true {
        if a == 10 {
            break;
        } else {
            a++;
        }
    }

    for (let i: ulong = 0; i < 100; i++) {
        a -= 2;
        continue;
    }

    do {
        a *= a * a;
    } while false;
}