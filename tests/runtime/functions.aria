int result = 0; // Expected to be 24

fn external_function(int a, int b, int c) -> void;

fn add(int lhs, int rhs) -> int {
    return lhs + rhs;
}

fn sub(int lhs, int rhs) -> int {
    return lhs - rhs;
}

int otherResult = 0; // Expected to be 26

fn main() -> void {
    result = add(5, 9);
    result = result + add(sub(6, 3), 7);
    otherResult = result + 2;

    external_function(5, 9 * 7 + 3, (5 + 5) * 5);
}