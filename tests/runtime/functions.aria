int result = 0; // Expected to be 24

fn void ExternalFunction(int a, int b, int c);

fn int add(int lhs, int rhs) {
    return lhs + rhs;
}

fn int sub(int lhs, int rhs) {
    return lhs - rhs;
}

int otherResult = 0; // This is here to confirm that you can have code in between function definitions

fn void main() {
    result = add(5, 9);
    result = result + add(sub(6, 3), 7);
    otherResult = result + 2;

    ExternalFunction(5, 9 * 7 + 3, (5 + 5) * 5);
}