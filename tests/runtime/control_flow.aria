module control_flow;

// Should return 10
fn test_while() -> int {
    let i: int = 0;
    while i < 10 {
        i = i + 1;
    }

    return i;
}

// Should return 10
fn test_do_while1() -> int {
    let i: int = 0;
    do {
        i = i + 1;
    } while i < 10;

    return i;
}

// Should return true
// True means that the loop was ran before the condition was checked, which is the correct behavior
fn test_do_while2() -> bool {
    do {
        return true;
    } while false;

    return false;
}

// Should return 190
fn test_for() -> int {
    let result: int = 0;
    
    for (let i: int = 0; i < 20; i += 1) {
        result += i;
    }
    
    return result;
}

// Should return 69
fn test_break() -> int {
    for (let i: int = 0;; i += 1) {
        if (i == 0) { break; }

        return 67;
    }

    return 69;
}

fn test_if() -> bool {
    if 4 < 6 {
        return false;
    }

    return true;
}