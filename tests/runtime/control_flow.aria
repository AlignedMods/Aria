// Should return 10
fn int While() {
    int i = 0;
    while i < 10 {
        i = i + 1;
    }

    return i;
}

// Should return 10
fn int DoWhile1() {
    int i = 0;
    do {
        i = i + 1;
    } while i < 10;

    return i;
}

// Should return true
// True means that the loop was ran before the condition was checked, which is the correct behavior
fn bool DoWhile2() {
    do {
        return true;
    } while false;

    return false;
}

