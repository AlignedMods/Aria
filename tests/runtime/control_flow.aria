// Should return 10
fn While() -> int {
    int i = 0;
    while i < 10 {
        i = i + 1;
    }

    return i;
}

// Should return 10
fn DoWhile1() -> int {
    int i = 0;
    do {
        i = i + 1;
    } while i < 10;

    return i;
}

// Should return true
// True means that the loop was ran before the condition was checked, which is the correct behavior
fn DoWhile2() -> bool {
    do {
        return true;
    } while false;

    return false;
}

// Should return 190
fn For() -> int {
    int result = 0;
    
    for (int i = 0; i < 20; i += 1) {
        result += i;
    }
    
    return result;
}

// Should return 69
fn Break() -> int {
    for (int i = 0;; i += 1) {
        if (i == 0) { break; }

        return 67;
    }

    return 69;
}

fn If() -> bool {
    if 4 < 6 {
        return false;
    }

    return true;
}