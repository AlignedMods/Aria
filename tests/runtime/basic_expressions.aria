fn should_never_be_called() -> bool #extern;

int a = 5 + 5;
int b = (a + 5) / -5;
int c = 1 + (2 * 3) - b; // Should be 10

bool d = false && false; // Should be false
bool e = false && true; // Should be false
bool f = true && true; // Should be true
bool g = f && (true && false); // Should be false

bool h = false || true; // Should be true
bool i = true || true; // Should be true
bool j = false || false; // Should be false
bool k = j || (true && h); // Should be true

int l = 2 << 4; // Should be 32
int m = 128 >> (a - 3); // Should be 1
int n = m ^ m; // Should be 0
int o = 5 & 4; // Should be 4
int p = o | o * o; // Should be 20

// This next section validates that && and || don't execute code that is not neccesary
bool aa = false && should_never_be_called();
bool bb = true || should_never_be_called();

// This next section handles compound assignment
int cc = 1;
int cca = cc += 3;
int dd = 0x05;
int dda = dd *= 0x05 + 0x05;