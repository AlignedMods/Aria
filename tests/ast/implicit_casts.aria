let a: int = 9; // Should have an implicit cast for LongToInt
let aa: int = a; // Should have an implicit cast for LValueToRValue
let b: float = a; // Should have an implicit cast for IntToFloat
let c: short = 5; // Should have an implicit cast for LongToShort
let d: long = c; // Should have an implicit cast for ShortToLong

let e: float = 5 * b / c; // 5 and c should be casted to floats, b should have a LValueToRValue cast