int a = 9; // Should have an implicit cast for LongToInt
int aa = a; // Should have an implicit cast for LValueToRValue
float b = a; // Should have an implicit cast for IntToFloat
short c = 5; // Should have an implicit cast for LongToShort
long d = c; // Should have an implicit cast for ShortToLong

float e = 5 * b / c; // 5 and c should be casted to floats, b should have a LValueToRValue cast