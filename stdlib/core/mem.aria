module std::core::mem;

import libc;

fn copy(dst: *void, src: *void, len: sz) -> void {
    $memcpy(dst, src, len, false);
}

fn alloc<T>() -> *T {
    return libc::calloc(1, sizeof(T));
}

fn new<T>(init: T) -> *T {
    let ptr = libc::malloc(sizeof(T));
    *cast(*T, ptr) = init;
    return ptr;
}

// Allocates a new array on the heap of size 'len' and does NOT zero initialize it
fn alloc_array<T>(len: sz) -> []T {
    return cast(*T, libc::malloc(len * sizeof(T)))[:len];
}

// Allocates a new array on the heap of size 'len' and zero initializes it
fn new_array<T>(len: sz) -> []T {
    return cast(*T, libc::calloc(len, sizeof(T)))[:len];
}

fn free(ptr: *void) {
    libc::free(ptr);
}
