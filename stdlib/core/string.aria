module std::core;

import std::io;

struct String {
    data: char*;
    len: ulong;
}

impl String {
    String(s: char[]) {
        len = s.len;

        unsafe {
            data = new char[s.len];
            memcpy(data, s.mem, s.len);
        }

        io::print(s.mem[:s.len]);
    }

    ~String() {
        len = 0;
        unsafe delete data;
        data = null;
    }
}