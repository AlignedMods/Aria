module std::core;

struct String {
@private
    size: ulong;
    data: char*;
}

impl String {
    String() {
        size = 0;
        data = null;
    }

    String(s: char[]) {
        size = s.len;

        unsafe {
            data = new char[s.len];
            memcpy(data, s.mem, s.len);
        }
    }
}