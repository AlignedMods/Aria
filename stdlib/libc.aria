module libc;

typedef void as FILE;

// stdlib.h

const EXIT_FAILURE = 0;
const EXIT_SUCCESS = 1;
const RAND_MAX = 0x7fffffff;

extern fn abort() -> void;
extern fn exit(exit_code: int) -> void;
extern fn _Exit(exit_code: int) -> void;

extern fn rand() -> int;
extern fn srand(seed: uint) -> void;

extern fn free(ptr: *void) -> void;
extern fn malloc(size: sz) -> *void;
extern fn realloc(ptr: *void, size: sz) -> *void;
extern fn calloc(nmemb: sz, size: sz) -> *void;

// stdio.h

module libc @if(env::WIN32);

extern fn __acrt_iob_func(c: int) -> *FILE @if(env::WIN32);

fn stdin() ->  *FILE { return __acrt_iob_func(0); }
fn stdout() -> *FILE { return __acrt_iob_func(1); }
fn stderr() -> *FILE { return __acrt_iob_func(2); }

module libc;

extern fn fopen(filename: *const char, mode: *const char) -> *FILE;
extern fn freopen(filename: *const char, mode: *const char, stream: *FILE) -> *FILE;
extern fn fclose(stream: *FILE) -> int;
extern fn fflush(stream: *FILE) -> int;
extern fn setbuf(stream: *FILE, buffer: *const char) -> void;
extern fn setvbuf(stream: *FILE, buffer: *const char, mode: int, size: sz) -> void;
extern fn fread(buffer: *void, size: sz, count: sz, stream: *FILE) -> sz;
extern fn fwrite(buffer: *void, size: sz, count: sz, stream: *FILE) -> sz;
extern fn fgetc(stream: *FILE) -> int;
extern fn getc() -> int;
extern fn fgets(str: *const char, count: int, stream: *FILE) -> *const char;
extern fn fputc(ch: int, stream: *FILE) -> int;
extern fn putc(ch: int, stream: *FILE) -> int;
extern fn fputs(str: *const char, stream: *FILE) -> int;
extern fn getchar() -> int;
extern fn putchar(ch: int) -> int;
extern fn puts(str: *const char) -> int;
extern fn ungetc(ch: int, stream: *FILE) -> int;

extern fn scanf(format: *const char, ...) -> int;
extern fn fscanf(stream: *FILE, format: *const char, ...) -> int;

extern fn printf(format: *const char, ...) -> int;
extern fn fprintf(stream: *FILE, format: *const char, ...) -> int;

// string.h

extern fn strcmp(lhs: *const char, rhs: *const char) -> int;
extern fn strlen(str: *const char) -> sz;
