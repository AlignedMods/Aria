module std::io;

struct File {
    handle: *void;
}

fn println(str: String) -> void {
    let s: StringStream;
    defer s.free();
    s.append_string(str);
    s.append_char('\n');

    printf(c"%s", s.to_ptr());
}

fn print(str: String) -> void {
    let s: StringStream;
    defer s.free();
    s.append_string(str);

    printf(c"%s", s.to_ptr());
}

#private

extern fn printf(s: *char, ...) -> int;
