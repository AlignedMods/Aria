module std::io;

import std::core;

fn println(str: char[]) -> void {
    let s: StringStream;
    s.append(str);
    s.append('\n');

    printf(s.to_ptr());
}

fn print(str: char[]) -> void {
    let s: StringStream;
    s.append(str);

    printf(s.to_ptr());
}

@private

extern fn printf(s: char*) -> int;