module std::io;

struct Stream {
    Stream() {
        data = null;
        size = 0;
        capacity = 0;

        io::print("Stream ctor called");
    }

    data: char*;
    size: ulong;
    capacity: ulong;
}

fn print(s: char[]) -> void @extern("__aria_raw_print_stdout()");

fn ok() -> void {
    let s: Stream;
    s->data = null;
}