module std::io;

fn println(str: char[]) -> void {
    let s: StringStream;
    defer s.free();
    s.append(str);
    s.append('\n');

    printf(c"%s", s.to_ptr());
}

fn print(str: char[]) -> void {
    let s: StringStream;
    defer s.free();
    s.append(str);

    printf(c"%s", s.to_ptr());
}

@private

extern fn printf(s: const char*, ...) -> int;